# .env.example - Copy to .env and fill in values

# API Configuration (for J7 - Frontend Integration)
# VITE_API_URL is the endpoint to your Lambda functions
# Format: https://{api-id}.execute-api.{region}.amazonaws.com/{stage}
VITE_API_URL=https://xxxxxxx.execute-api.eu-west-3.amazonaws.com/dev

# Note: Keep this file in git, but add .env to .gitignore
# Real values stay in .env (not committed)

